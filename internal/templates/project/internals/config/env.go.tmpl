package config

import (
	"fmt"
	"os"
[[- if .HasConsumer]]
	"time"
[[- end]]

	"github.com/triasbrata/higo-framework/instrumentation"
[[- if .HasConsumer]]
	"github.com/triasbrata/higo-framework/messagebroker/broker/impl"
[[- end]]
[[- if .HasPyroscope]]
	pypkg "github.com/triasbrata/higo-framework/pyroscope"
[[- end]]
[[- if .HasConsumer]]
	serverConsumer "github.com/triasbrata/higo-framework/server/consumer"
[[- end]]
[[- if .HasGRPC]]
	grpcserver "github.com/triasbrata/higo-framework/server/grpc"
[[- end]]
[[- if .HasHTTP]]
	httpserver "github.com/triasbrata/higo-framework/server/http"
[[- end]]
	"github.com/triasbrata/higo-framework/secrets"
)

func NewConfigEnv(secret secrets.Secret) (*Config, error) {
	cafile, err := os.ReadFile(secret.GetSecretAsString("OTEL_CA_PATH", ""))
	if err != nil && !os.IsNotExist(err) {
		return nil, fmt.Errorf("cant read ca file for instrumentation")
	}
	if caStr := secret.GetSecretAsString("OTEL_CA_CONTENT", ""); caStr != "" {
		cafile = []byte(caStr)
	}

	cfg := &Config{
		Otel: instrumentation.InstrumentationConfig{
			AppName:                secret.GetSecretAsString("APP_NAME", "[[.AppName]]"),
			CaFile:                 cafile,
			Endpoint:               secret.GetSecretAsString("OTEL_ENDPOINT", "localhost:4317"),
			UseGRPC:                secret.GetSecretAsBool("OTEL_USE_GRPC", true),
			UseHttp:                !secret.GetSecretAsBool("OTEL_USE_GRPC", true),
			IntegrateWithPyroscope: secret.GetSecretAsBool("PYROSCOPE_ENABLED", false),
		},
[[- if .HasHTTP]]
		Http: httpserver.HttpServerConfig{
			Port:    secret.GetSecretAsString("HTTP_PORT", "8000"),
			Address: secret.GetSecretAsString("HTTP_ADDRESS", ""),
		},
[[- end]]
[[- if .HasGRPC]]
		Grpc: grpcserver.GrpcServerConfig{
			EnableReflection: true,
			Port:             secret.GetSecretAsString("GRPC_PORT", "8001"),
			Address:          secret.GetSecretAsString("GRPC_ADDRESS", ""),
		},
[[- end]]
[[- if .HasPyroscope]]
		Pyroscope: pypkg.PyroscopeConfig{
			Enabled:       secret.GetSecretAsBool("PYROSCOPE_ENABLED", false),
			ServerAddress: secret.GetSecretAsString("PYROSCOPE_SERVER_ADDRESS", "http://localhost:9999"),
		},
[[- end]]
[[- if .HasConsumer]]
		Amqp: impl.AmqpConfig{
			ConnectionName: secret.GetSecretAsString("AMQP_CONNECTION_NAME", "[[.AppName]]-consumer"),
			URI:            secret.GetSecretAsString("AMQP_URI", "amqp://guest:guest@localhost:5672"),
		},
		Consumer: serverConsumer.ConsumerServerConfig{
			RestartTime: 5 * time.Second,
		},
[[- end]]
	}
	return cfg, nil
}
